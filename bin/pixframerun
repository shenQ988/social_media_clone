#!/bin/bash
#
# pixframerun
#
# Clean, build and start server
#

# Stop on errors, print commands
set -Eeuo pipefail
set -x

DATABASE_URL="${DATABASE_URL:-postgresql://pixframe:pixframe@localhost:5433/pixframe}"

# 1. Check that Postgres is reachable and the database has been seeded
if ! psql "$DATABASE_URL" -tAc \
    "SELECT 1 FROM information_schema.tables WHERE table_name='users'" \
    2>/dev/null | grep -q 1; then
    echo "Error: can't find the pixframe database (or Postgres isn't running)"
    echo "Start Postgres (e.g. docker run ... postgres:16), then: ./bin/pixframedb create"
    exit 1
fi

# 2. Add the trap to kill background processes (webpack) on exit
# This ensures that when you hit Ctrl+C, it stops both the backend and Webpack.
trap "trap - SIGTERM && kill -- -$$" SIGINT SIGTERM EXIT

# 3. Start webpack in watch mode in the background
# The '&' is crucial—it lets the script continue to the next line (Spring Boot)
# while webpack keeps running and watching for file changes.
npx webpack --watch &

# 4. Run the Spring Boot development server (port 8000, same as before)
mvn -f backend/pom.xml spring-boot:run
