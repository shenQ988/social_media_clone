#!/bin/bash
#
# pixframerun
#
# Clean, build and start server
#

# Stop on errors, print commands
set -Eeuo pipefail
set -x

# 1. Check if the database exists
if [ ! -f var/pixframe.sqlite3 ]; then
    echo "Error: can't find database var/pixframe.sqlite3"
    echo "Try: ./bin/pixframedb reset"
    exit 1
fi

# 2. Add the trap to kill background processes (webpack) on exit
# This ensures that when you hit Ctrl+C, it stops both Flask and Webpack.
trap "trap - SIGTERM && kill -- -$$" SIGINT SIGTERM EXIT

# 3. Start webpack in watch mode in the background
# The '&' is crucial—it lets the script continue to the next line (Flask)
# while webpack keeps running and watching for file changes.
npx webpack --watch &

# 4. Run the Flask development server
flask --app pixframe --debug run --host 0.0.0.0 --port 8000