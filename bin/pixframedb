#!/bin/bash
# pixframedb
#
# Drives the Postgres database via psql. Connection info comes from
# DATABASE_URL if set, otherwise defaults to the local dev Postgres
# container documented in the README / migration plan:
#   docker run --name pixframe-pg -e POSTGRES_USER=pixframe \
#     -e POSTGRES_PASSWORD=pixframe -e POSTGRES_DB=pixframe \
#     -p 5432:5432 -d postgres:16

# Stop on errors
# See https://vaneyckt.io/posts/safer_bash_scripts_with_set_euxo_pipefail/
set -Eeuo pipefail
set -x

DATABASE_URL="${DATABASE_URL:-postgresql://pixframe:pixframe@localhost:5432/pixframe}"

# Sanity check command line options
usage() {
  echo "Usage: $0 (create|destroy|reset|dump|random)"
}

if [ $# -ne 1 ]; then
    usage
    exit 1
fi

# Parse argument.  $1 is the first argument
case $1 in
    "create")

    # check if the database already has our tables, to avoid clobbering
    if psql "$DATABASE_URL" -tAc \
        "SELECT 1 FROM information_schema.tables WHERE table_name='users'" \
        | grep -q 1; then
        echo "Error: database already exists"
        exit 1
    fi

    mkdir -p var/uploads
    psql "$DATABASE_URL" -f sql/schema.sql
    psql "$DATABASE_URL" -f sql/data.sql
    cp sql/uploads/* var/uploads/
    ;;

"destroy")
    psql "$DATABASE_URL" -c \
        "DROP TABLE IF EXISTS comments, likes, following, posts, users CASCADE;"
    rm -rf var/uploads
    ;;

"reset")
    psql "$DATABASE_URL" -c \
        "DROP TABLE IF EXISTS comments, likes, following, posts, users CASCADE;"
    rm -rf var/uploads
    mkdir -p var/uploads
    psql "$DATABASE_URL" -f sql/schema.sql
    psql "$DATABASE_URL" -f sql/data.sql
    cp sql/uploads/* var/uploads/
    ;;

"dump")
    psql "$DATABASE_URL" -c 'SELECT * FROM comments'
    psql "$DATABASE_URL" -c 'SELECT * FROM following'
    psql "$DATABASE_URL" -c 'SELECT * FROM likes'
    psql "$DATABASE_URL" -c 'SELECT * FROM posts'
    psql "$DATABASE_URL" -c 'SELECT * FROM users'
    ;;
  "random")
    if command -v magick &> /dev/null; then
      IM_CMD="magick"
    elif command -v convert &> /dev/null; then
      IM_CMD="convert"
    else
      echo "Error: Neither 'magick' nor 'convert' command found."
      exit 1
    fi

    for i in `seq 1 100`; do
      FILENAME="$(uuidgen).png"
      NUMS=()
      for j in `seq 1 6`; do
          NUMS+=($(($RANDOM % 255)))
      done
      "$IM_CMD" -size 360x360 \
              radial-gradient:"rgb(${NUMS[0]},${NUMS[1]},${NUMS[2]})-rgb(${NUMS[3]},${NUMS[4]},${NUMS[5]})" \
              -pointsize 64 -fill black -gravity center -annotate 0 "image $i" "var/uploads/$FILENAME"
      OWNER="mkim"
      psql "$DATABASE_URL" -c \
        "INSERT INTO posts(filename, owner) VALUES('${FILENAME}','${OWNER}');"
    done
    ;;

  *)
    usage
    exit 1
    ;;
esac
